# Go module / build caches (never commit — e.g. ad-hoc `go run` / tests)
.gocache/
.gomodcache/

# Ad-hoc scratch (local experiments, packaging test output)
tmp/

# Built Go binaries under src/bin (launchers stay as shell scripts; see Makefile / src/Makefile)
src/bin/dorkpipe
src/bin/mcpd

# Local Cursor / remote server / IDE (binaries, keys, workspace state — do not commit)
.cache/
.cursor-server/
.cursor/
.devcontainer/
.ssh/

# Build output
# Legacy out-of-tree Pipeon Launcher build (prefer: src/apps/pipeon-launcher/build)
build-pipeon-launcher/
release/packaging/build/
*.deb
src/bin/dockpipe.bin
src/bin/dockpipe.exe
# ad-hoc go build -o in repo root (prefer: make build-windows → src/bin/dockpipe.exe)
/dockpipe.exe
msi-dist/
*.wixobj
*.wixpdb
# Legacy local output (prefer release/artifacts)
dist/
# Local publish + CI-style release binaries (templates-core tarball, nfpm, tar.gz, etc.)
release/artifacts/

# Local demo recordings (asciinema + agg)
release/demo/dockpipe-demo*.cast
release/demo/dockpipe-demo*.gif

# OS
.DS_Store
Thumbs.db

# Editor / temp
*~
*.swp
*.swo
.*.sw?

# SR&ED evidence and timekeeping (local only; see .local/sred/README.md)
.local/sred/

# Optional local overrides (do not commit)
.env
.env.local
# 1Password inject template (op:// refs; often names private vaults — keep local)
.env.op.template
.env.secretstore

# Maintainer-only trees under .staging — keep local experiments out of git; embed.go still embeds paths from a full checkout.
# Exception: umbrella package.yml (kind: package) under dockpipe/agent|ide|secrets|cloud/storage — tracked; resolvers/ and everything else stays ignored.
.staging/*
!.staging/packages/
!.staging/packages/README.md
.staging/packages/*
!.staging/packages/dockpipe/
.staging/packages/dockpipe/*
!.staging/packages/dockpipe/agent/
!.staging/packages/dockpipe/ide/
!.staging/packages/dockpipe/secrets/
.staging/packages/dockpipe/agent/*
!.staging/packages/dockpipe/agent/package.yml
.staging/packages/dockpipe/ide/*
!.staging/packages/dockpipe/ide/package.yml
.staging/packages/dockpipe/secrets/*
!.staging/packages/dockpipe/secrets/package.yml
!.staging/packages/dockpipe/cloud/
!.staging/packages/dockpipe/cloud/storage/
.staging/packages/dockpipe/cloud/storage/*
!.staging/packages/dockpipe/cloud/storage/package.yml
# To stop tracking without deleting files: git rm -r --cached .staging
# Note: CI/fresh clones need a populated .staging tree for go:embed or a future embed-from-tracked-dir change.

# Local `.dockpipe/` — generated handoffs, CI dumps, review/cursor prompts, optional `demo/` stubs (see AGENTS.md).
# Canonical bundled core + workflows live under `src/core/…`; do not commit a duplicate `templates/` tree here.
.dockpipe/

# DorkPipe runtime outputs (metrics, nodes, self-analysis scratch)
.dorkpipe/

# Terraform (e.g. .staging/packages/dockpipe/cloud/storage/resolvers/r2/dockpipe.cloudflare.r2publish/terraform — keep .terraform.lock.hcl)
.terraform/
*.tfstate
*.tfstate.*

# VS Code extension (packed / dev)
src/contrib/pipeon-vscode-extension/node_modules/
src/contrib/pipeon-vscode-extension/*.vsix
