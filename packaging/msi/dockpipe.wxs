<?xml version="1.0" encoding="UTF-8"?>
<!-- WiX 3.x — build on Windows: see build.ps1 -->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">
  <Product Id="*"
           Name="dockpipe"
           Language="1033"
           Version="$(var.ProductVersion)"
           Manufacturer="Jamie Steele"
           UpgradeCode="B7E3F2A1-4C5D-6E7F-8091-A2B3C4D5E6F7">

    <!-- perUser: quiet install without admin (typical for dev CLIs) -->
    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perUser"
             Description="dockpipe — run commands in disposable containers"
             Comments="Apache-2.0"
             Manufacturer="Jamie Steele" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of dockpipe is already installed."
                  AllowSameVersionUpgrades="no" />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="dockpipe" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="INSTALLFOLDER" Name="dockpipe" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="cmp_dockpipe_exe" Guid="*">
        <File Id="fil_dockpipe_exe"
              Source="$(var.DockpipeSource)"
              KeyPath="yes" />
        <!-- Append install dir to machine PATH (WiX UtilExtension) -->
        <util:Environment Id="env_path_dockpipe"
                          Action="set"
                          Name="PATH"
                          Value="[INSTALLFOLDER]"
                          Part="last"
                          Permanent="no"
                          System="no" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
