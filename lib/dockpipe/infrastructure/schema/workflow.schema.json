{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dockpipe.dev/schema/workflow.schema.json",
  "title": "Dockpipe workflow",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "imports": {
      "type": "array",
      "items": { "type": "string" }
    },
    "vars": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "run": {},
    "isolate": { "type": "string" },
    "act": { "type": "string" },
    "action": { "type": "string" },
    "resolver": { "type": "string" },
    "default_resolver": { "type": "string" },
    "runtime": { "type": "string" },
    "default_runtime": { "type": "string" },
    "runtimes": { "type": "array", "items": { "type": "string" } },
    "strategy": { "type": "string" },
    "strategies": { "type": "array", "items": { "type": "string" } },
    "docker_preflight": { "type": "boolean", "description": "When false, skip Docker reachability preflight when no step uses the container runner (host-only workflows)." },
    "steps": { "type": "array" },
    "resolvers": { "type": "array", "items": { "type": "string" } }
  }
}
