#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
TARGET="$ROOT/bin/.dockpipe/tooling/bin/mcpd"

if [[ ! -x "$TARGET" ]]; then
  echo "mcpd wrapper: missing maintainer binary at $TARGET" >&2
  echo "Run: make maintainer-tools" >&2
  exit 1
fi

exec "$TARGET" "$@"
