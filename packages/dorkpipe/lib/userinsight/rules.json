{
  "schema_version": "1.0",
  "description": "Deterministic classification rules for dorkpipe insight process. Edit patterns to tune behavior; no hidden ML.",
  "default_category": "unknown",
  "auto_promote_categories": ["convention", "architecture_note", "future_work"],
  "review_required_categories": ["compliance", "risk", "constraint"],
  "classifiers": [
    {
      "pattern": "(?i)(SOC\\s*2|ISO\\s*27001|HIPAA|GDPR|PCI|compliance|audit|regulator)",
      "category": "compliance",
      "force_review": true
    },
    {
      "pattern": "(?i)(risk|threat|attack|exploit|vulnerability|CVE|danger|unsafe)",
      "category": "risk",
      "force_review": true
    },
    {
      "pattern": "(?i)(must not|must never|do not|forbidden|illegal|constraint|invariant|required to)",
      "category": "constraint",
      "force_review": true
    },
    {
      "pattern": "(?i)(convention|naming|style guide|\\bprefer\\b|always use )",
      "category": "convention",
      "force_review": false
    },
    {
      "pattern": "(?i)(architecture|layering|boundary|dependency rule|module boundary)",
      "category": "architecture_note",
      "force_review": false
    },
    {
      "pattern": "(?i)(TODO|future|later|roadmap|eventually|nice to have)",
      "category": "future_work",
      "force_review": false
    }
  ]
}
