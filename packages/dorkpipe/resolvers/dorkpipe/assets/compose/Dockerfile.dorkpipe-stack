FROM debian:bookworm-slim

RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends bash ca-certificates git jq openssh-client python3 ripgrep; \
    rm -rf /var/lib/apt/lists/*

COPY tooling/bin/linux/dockpipe /usr/local/bin/dockpipe
COPY tooling/bin/linux/dorkpipe /usr/local/bin/dorkpipe
COPY tooling/bin/linux/mcpd /usr/local/bin/mcpd

RUN chmod +x /usr/local/bin/dockpipe /usr/local/bin/dorkpipe /usr/local/bin/mcpd

ENTRYPOINT ["/bin/bash", "-lc"]
