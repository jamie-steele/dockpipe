FROM debian:bookworm-slim

RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends bash ca-certificates git openssh-client ripgrep; \
    rm -rf /var/lib/apt/lists/*

COPY src/bin/dockpipe /usr/local/bin/dockpipe
COPY bin/.dockpipe/tooling/bin/dorkpipe /usr/local/bin/dorkpipe
COPY bin/.dockpipe/tooling/bin/mcpd /usr/local/bin/mcpd

RUN chmod +x /usr/local/bin/dockpipe /usr/local/bin/dorkpipe /usr/local/bin/mcpd

ENTRYPOINT ["/bin/bash", "-lc"]
