/// <summary>
/// Contract for the 1Password-backed secretstore workflow variables.
/// </summary>
public Interface ISecretstoreOnepasswordConfig
{
    /// <summary>Secretstore backend selector. This workflow is pinned to 1Password.</summary>
    public string SecretstoreProvider;
    /// <summary>Path to the env template file containing op:// references.</summary>
    public string OpEnvFile;
}
