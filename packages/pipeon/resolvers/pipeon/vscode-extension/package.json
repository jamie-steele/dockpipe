{
  "name": "pipeon",
  "displayName": "DorkPipe",
  "description": "DorkPipe editor companion: local-first chat, workflow actions, and workspace context from .dockpipe.",
  "version": "0.0.1",
  "publisher": "dorkpipe",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamie-steele/dockpipe.git"
  },
  "icon": "images/dorkpipe-icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished", "onView:pipeon.chatView", "onCommand:pipeon.openChat"],
  "files": [
    "extension.js",
    "images/**",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "main": "extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pipeon",
          "title": "DorkPipe",
          "icon": "images/dorkpipe-icon.png"
        }
      ]
    },
    "views": {
      "pipeon": [
        {
          "id": "pipeon.chatView",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "pipeon.openChat",
        "title": "DorkPipe: Focus chat"
      },
      {
        "command": "pipeon.openContextBundle",
        "title": "DorkPipe: Open context bundle (bin/.dockpipe/pipeon-context.md)"
      },
      {
        "command": "pipeon.showReadme",
        "title": "DorkPipe: Open docs"
      }
    ]
  },
  "license": "Apache-2.0"
}
