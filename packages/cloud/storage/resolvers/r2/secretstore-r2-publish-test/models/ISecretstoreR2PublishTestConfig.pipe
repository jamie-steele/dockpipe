/// <summary>
/// Contract for the 1Password-to-R2 publish smoke-test workflow variables.
/// </summary>
public Interface ISecretstoreR2PublishTestConfig
{
    /// <summary>Path to the template file consumed by op inject.</summary>
    public string OpEnvFile;
    /// <summary>Outputs file written by the inject step and merged into the later publish step.</summary>
    public string SecretEnvOut;
}
