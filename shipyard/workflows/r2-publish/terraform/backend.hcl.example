# Example backend config for manual `terraform init -backend-config=...`.
# The r2-publish.sh script generates this from env (bucket/key/endpoint defaults).
# Replace ACCOUNT_ID and use R2 S3 keys (Object Read & Write on the state bucket).

bucket = "dockpipe"
key    = "state/r2-publish/terraform.tfstate"
region = "auto"

skip_credentials_validation = true
skip_metadata_api_check     = true
skip_region_validation      = true
skip_requesting_account_id  = true
skip_s3_checksum            = true
use_path_style              = true

endpoints = { s3 = "https://ACCOUNT_ID.r2.cloudflarestorage.com" }
