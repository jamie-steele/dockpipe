# Resolver: 1Password CLI on the host (op inject / op run).
# Pair with runtime: cli and skip_container steps. Does not start a tool container — use for
# workflows that load secrets via 1Password before other host steps (see .staging/workflows/secretstore-r2-publish-test).
DOCKPIPE_RESOLVER_CMD=op
# Hint for env merge / docs — add keys your op template injects.
DOCKPIPE_RESOLVER_ENV=CLOUDFLARE_API_TOKEN,CLOUDFLARE_ACCOUNT_ID,R2_BUCKET,R2_STATE_ACCESS_KEY_ID,R2_STATE_SECRET_ACCESS_KEY
