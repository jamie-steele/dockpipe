DOCKPIPE_RESOLVER_CMD=code-server
DOCKPIPE_RESOLVER_PRE_SCRIPT=scripts/clone-worktree.sh
DOCKPIPE_RESOLVER_ACTION=scripts/commit-worktree.sh
