{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dockpipe.dev/schema/workflow.schema.json",
  "title": "Dockpipe workflow",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "string_or_string_array": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    },
    "string_map": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "input_scalar": {
      "oneOf": [
        { "type": "string" },
        { "type": "boolean" },
        { "type": "integer" },
        { "type": "number" }
      ]
    },
    "input_binding": {
      "oneOf": [
        { "$ref": "#/$defs/input_scalar" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "from": { "type": "string" },
            "value": { "$ref": "#/$defs/input_scalar" }
          }
        }
      ]
    },
    "input_map": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/input_binding" }
    },
    "step_vm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mounts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "host": { "type": "string" },
              "guest": { "type": "string" }
            }
          }
        },
        "host_context": { "type": "string" },
        "guest_path": { "type": "string" },
        "interactive_debug": { "type": "boolean" },
        "interactive_ssh": { "type": "boolean" },
        "keepalive": { "type": "boolean" },
        "keepalive_seconds": {
          "oneOf": [
            { "type": "string" },
            { "type": "integer" }
          ]
        },
        "hostfwd": { "type": "string" }
      }
    },
    "container_mount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string" },
        "guest": { "type": "string" },
        "mode": { "type": "string", "enum": ["ro", "rw"] }
      }
    },
    "container_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workdir_host": { "type": "string" },
        "work_path": {
          "type": "string",
          "description": "Container working subdirectory under /work. Must stay relative to the primary work mount."
        },
        "mounts": {
          "type": "array",
          "items": { "$ref": "#/$defs/container_mount" }
        }
      }
    },
    "workspace_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repo": {
          "type": "string",
          "description": "Logical repository identity or source path/URL for runtime-owned workspace sessions."
        },
        "mode": {
          "type": "string",
          "enum": ["managed", "bind"],
          "description": "Workspace storage mode. managed creates a DockPipe-owned session workspace; bind opts into the current checkout."
        },
        "base": {
          "type": "string",
          "description": "Base ref for the session branch. Defaults to HEAD."
        },
        "storage": {
          "type": "string",
          "enum": ["volume", "worktree", "clone"],
          "description": "Advanced storage implementation hint. volume mounts a runtime Docker volume at /work while keeping a managed worktree for checkpoints; clone is reserved for future distributed workers. Most workflows should omit this."
        },
        "lifecycle": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "branch_prefix": {
              "type": "string",
              "description": "Prefix for runtime-created session branches. Defaults to ai."
            },
            "branch": {
              "type": "string",
              "description": "Exact session branch name. Use when the repository has a required branch naming convention; overrides branch_prefix-derived names."
            },
            "checkpoint": {
              "type": "string",
              "enum": ["manual", "auto", "step"],
              "description": "Runtime checkpoint policy."
            },
            "publish": {
              "type": "string",
              "enum": ["none", "branch", "review"],
              "description": "Future runtime publish policy. Merge remains human-controlled."
            }
          }
        }
      }
    },
    "agent_model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "temperature": { "type": "number" },
        "top_p": { "type": "number" },
        "num_predict": { "type": "integer" },
        "num_ctx": { "type": "integer" },
        "keep_alive": {
          "oneOf": [
            { "type": "string" },
            { "type": "integer" }
          ]
        },
        "escalation_provider": { "type": "string" },
        "escalation_model": { "type": "string" }
      }
    },
    "agent_access": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "read": {
          "type": "array",
          "items": { "type": "string" }
        },
        "write": {
          "type": "array",
          "items": { "type": "string" }
        },
        "deny": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "model_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string" },
        "execution_mode": {
          "type": "string",
          "enum": ["workflow", "provider_pool"],
          "description": "Execution substrate for DorkPipe agent workers. Use provider_pool only when selected workflow/subagent nodes should lease the shared provider pool."
        },
        "role": {
          "type": "string",
          "description": "Provider-neutral worker role label used for provider-pool attribution and session grouping."
        },
        "session_scope": {
          "type": "string",
          "enum": ["node", "workflow"],
          "description": "Provider-pool session reuse boundary. node isolates each subagent node; workflow reuses a role session within the orchestration run."
        },
        "max_active": {
          "type": "integer",
          "minimum": 1,
          "description": "Optional per-policy cap for active provider-pool leases. It can only narrow the provider catalog cap."
        },
        "queue_timeout_seconds": {
          "type": "integer",
          "minimum": 0,
          "description": "Seconds a provider-pool task waits for a lease before returning a visible queued failure."
        },
        "attempt": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "preference": { "type": "string" },
            "max_attempts": { "type": "integer" }
          }
        },
        "validate": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "preference": { "type": "string" },
            "required_for": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "escalation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "on": {
              "type": "array",
              "items": { "type": "string" }
            },
            "require_approval_over_cost": { "type": "boolean" }
          }
        }
      }
    },
    "agent_shared_item": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "collector": { "type": "string" },
        "text": { "type": "string" },
        "focus": { "type": "string" },
        "starting_points": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional collector starting points. These are hints for building the shared artifact, not access boundaries."
        }
      }
    },
    "agent_task": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "agent": {
          "type": "string",
          "description": "Reusable agent role id from agent.orchestration.agents. Role defaults supply worker/model/access/authority; task fields supply task-specific brief and context."
        },
        "brief": {
          "type": "string",
          "description": "Task-specific briefing text. Briefs are instructions/context, not a source boundary."
        },
        "context": { "$ref": "#/$defs/agent_task_context" },
        "goal": { "type": "string" },
        "expected_output": { "type": "string" },
        "prompt": { "type": "string" },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "claims": {
          "type": "array",
          "items": { "type": "string" }
        },
        "citations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "materialize_outputs": {
          "type": "array",
          "description": "DorkPipe task response files to extract from structured dorkpipe:file blocks into tasks/<id>/materialized/ for downstream inputs and apply outputs.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "path": {
                "type": "string",
                "description": "Relative artifact path under the task materialized directory. The worker response must include a matching <!-- dorkpipe:file path=\"...\" --> block."
              }
            },
            "required": ["path"]
          }
        },
        "max_cloud_tokens": { "type": "integer" }
      }
    },
    "agent_task_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_artifacts": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Prior artifacts or shared files that must be included as briefing context."
        },
        "seed_paths": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Concrete source paths used as starting points, not a hard source allowlist."
        },
        "source_roots": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Allowed source roots the role may inspect when needed, subject to access policy."
        }
      }
    },
    "agent_definition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "role": { "type": "string" },
        "worker": { "type": "string" },
        "worker_type": { "type": "string" },
        "work_mode": {
          "type": "string",
          "enum": ["artifact", "artifacts", "readonly", "read-only", "read-only-artifacts", "collect", "gather", "edit", "direct", "direct-edit", "workspace-edit", "writable"]
        },
        "worker_policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": { "type": "string", "enum": ["prefer", "require"] }
          }
        },
        "authority": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "can": {
              "type": "array",
              "items": { "type": "string" }
            },
            "cannot": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "accessible_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "access": { "$ref": "#/$defs/agent_access" },
        "model": { "$ref": "#/$defs/agent_model" },
        "model_policy": { "$ref": "#/$defs/model_policy" }
      }
    },
    "step_agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "startup_prompt": { "type": "string" },
        "include_agents_md": { "type": "boolean" },
        "accessible_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "access": { "$ref": "#/$defs/agent_access" },
        "task_id": { "type": "string" },
        "model": { "$ref": "#/$defs/agent_model" },
        "model_policy": { "$ref": "#/$defs/model_policy" },
        "orchestration": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "request": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "text": { "type": "string" }
              }
            },
            "plan": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "goal": { "type": "string" },
                "steps": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "concurrency": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "max_workers": {
                  "type": "integer",
                  "minimum": 1
                },
                "max_local_workers": {
                  "type": "integer",
                  "minimum": 1
                },
                "max_cloud_workers": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            },
            "shared": {
              "type": "array",
              "items": { "$ref": "#/$defs/agent_shared_item" }
            },
            "agents": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/agent_definition" }
            },
            "tasks": {
              "type": "array",
              "items": { "$ref": "#/$defs/agent_task" }
            },
            "merge": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string" },
                "title": { "type": "string" },
                "summary_points": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "verify": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string" },
                "next_action_default": { "type": "string" }
              }
            },
            "apply": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "require_approval": { "type": "boolean" },
                "target_root": { "type": "string" },
                "required_artifacts": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "outputs": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "source": { "type": "string" },
                      "path": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "inject_item": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "workflow": { "type": "string" },
            "package": { "type": "string" },
            "resolver": { "type": "string" }
          }
        }
      ]
    },
    "workflow_view_section": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "workflow_view_page": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/workflow_view_section" }
        }
      }
    },
    "workflow_view_entry_option": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": { "type": "string" },
        "label": { "type": "string" },
        "next": { "type": "string" },
        "pages": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "workflow_view_entry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string" },
        "field": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/workflow_view_entry_option" }
        }
      }
    },
    "dependencies_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "description": "Stable dependency id. Defaults to command when omitted."
              },
              "command": {
                "type": "string",
                "description": "Executable name expected on the host PATH."
              },
              "description": { "type": "string" },
              "required": {
                "type": "boolean",
                "description": "Defaults to true. Optional dependencies are documented but do not fail preflight."
              },
              "install": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "windows": { "type": "string" },
                  "macos": { "type": "string" },
                  "linux": { "type": "string" },
                  "deb": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "workflow_view": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entry": { "$ref": "#/$defs/workflow_view_entry" },
        "pages": {
          "type": "array",
          "items": { "$ref": "#/$defs/workflow_view_page" }
        }
      }
    },
    "image_customization": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packages": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "apt": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9+._:-]*$"
              },
              "description": "Debian apt packages to install into a derived Docker image for this workflow or step."
            }
          }
        }
      }
    },
    "workflow_step": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string", "enum": ["host", "container"] },
        "cwd": { "type": "string", "enum": ["source", "repo", "workdir", "artifacts", "artifact"] },
        "scopes": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "source": { "type": "string", "enum": ["source", "repo", "workdir", "artifacts", "artifact"] },
            "artifacts": { "type": "string", "enum": ["source", "repo", "workdir", "artifacts", "artifact"] }
          }
        },
        "cmd": { "type": "string" },
        "command": { "type": "string" },
        "run": { "$ref": "#/$defs/string_or_string_array" },
        "pre_script": { "type": "string" },
        "inputs": { "$ref": "#/$defs/input_map" },
        "vars": { "$ref": "#/$defs/string_map" },
        "vm": { "$ref": "#/$defs/step_vm" },
        "container": { "$ref": "#/$defs/container_config" },
        "agent": { "$ref": "#/$defs/step_agent" },
        "security": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "profile": {
              "type": "string",
              "enum": ["secure-default", "internet-client", "build-online", "sidecar-client"]
            },
            "network": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": ["offline", "restricted", "allowlist", "internet"]
                },
                "allow": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "block": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "filesystem": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "root": { "type": "string", "enum": ["readonly", "writable"] },
                "writes": { "type": "string", "enum": ["workspace-only", "declared"] },
                "writable_paths": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "temp_paths": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "process": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "user": { "type": "string", "enum": ["auto", "non-root", "root"] },
                "pid_limit": { "type": "integer", "minimum": 0 },
                "resources": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "cpu": { "type": "string" },
                    "memory": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "image": { "$ref": "#/$defs/image_customization" },
        "outputs": { "type": "string" },
        "workflow": {
          "type": "string",
          "description": "Child workflow name for a packaged workflow step."
        },
        "package": {
          "type": "string",
          "description": "Child workflow namespace for a packaged workflow step."
        },
        "runtime": { "type": "string" },
        "resolver": { "type": "string" },
        "isolate": { "type": "string" },
        "act": { "type": "string" },
        "action": { "type": "string" },
        "capture_stdout": { "type": "string" },
        "manifest": { "type": "string" },
        "host_builtin": {
          "type": "string",
          "enum": ["package_build_store", "compose_up", "compose_down", "compose_ps"]
        },
        "is_blocking": {
          "type": "boolean",
          "description": "Blocking control for explicit async groups. Plain-step is_blocking: false is not supported; use group.mode: async."
        }
      },
      "allOf": [
        {
          "if": {
            "anyOf": [
              { "required": ["workflow"] },
              { "required": ["package"] }
            ]
          },
          "then": {
            "required": ["workflow", "package"]
          }
        },
        {
          "if": { "required": ["host_builtin"] },
          "then": {
            "properties": {
              "kind": { "const": "host" }
            },
            "required": ["kind"]
          }
        }
      ]
    },
    "async_group": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "group": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": { "type": "string", "const": "async" },
            "tasks": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/workflow_step" }
            }
          },
          "required": ["mode", "tasks"]
        }
      },
      "required": ["group"]
    }
  },
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "category": {
      "type": "string",
      "description": "Optional UI hint: e.g. \"app\" = show in Pipeon Basic mode (launchable GUI/container tools)."
    },
    "icon": {
      "type": "string",
      "description": "Optional package-owned artwork path relative to the workflow config."
    },
    "workflow_type": {
      "type": "string",
      "description": "Optional classifier for tooling and templates (e.g. secretstore). Lowercase letters, digits, hyphens; must start with a letter. The engine does not branch on this field."
    },
    "namespace": {
      "type": "string",
      "description": "Optional author/org label for packages and discovery. Lowercase label (a-z, digits, hyphens); must not be a reserved word (e.g. dockpipe, core, system)."
    },
    "platforms": {
      "type": "array",
      "description": "Host platforms this workflow supports. Host steps and required dependencies must work on every declared platform.",
      "items": {
        "type": "string",
        "enum": ["windows", "macos", "linux", "deb"]
      }
    },
    "imports": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Relative YAML files to merge (file inclusion). Not named package dependencies."
    },
    "inject": {
      "type": "array",
      "description": "Explicit compile-closure dependencies for package compile for-workflow: workflow/package ids (string or workflow:/package: maps) and resolver: profile names. Does not merge YAML — use imports for that.",
      "items": { "$ref": "#/$defs/inject_item" }
    },
    "vars": { "$ref": "#/$defs/string_map" },
    "compose": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "file": { "type": "string" },
        "project": { "type": "string" },
        "project_directory": { "type": "string" },
        "autodown_env": { "type": "string" },
        "exports": { "$ref": "#/$defs/string_map" },
        "services": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "container": { "$ref": "#/$defs/container_config" },
    "workspace": { "$ref": "#/$defs/workspace_config" },
    "dependencies": { "$ref": "#/$defs/dependencies_config" },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["secure-default", "internet-client", "build-online", "sidecar-client"]
        },
        "network": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["offline", "restricted", "allowlist", "internet"]
            },
            "allow": {
              "type": "array",
              "items": { "type": "string" }
            },
            "block": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "filesystem": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "root": { "type": "string", "enum": ["readonly", "writable"] },
            "writes": { "type": "string", "enum": ["workspace-only", "declared"] },
            "writable_paths": {
              "type": "array",
              "items": { "type": "string" }
            },
            "temp_paths": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "process": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "user": { "type": "string", "enum": ["auto", "non-root", "root"] },
            "pid_limit": { "type": "integer", "minimum": 0 },
            "resources": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "run": { "$ref": "#/$defs/string_or_string_array" },
    "isolate": { "type": "string" },
    "act": { "type": "string" },
    "action": { "type": "string" },
    "resolver": { "type": "string" },
    "runtime": { "type": "string" },
    "vault": {
      "type": "string",
      "description": "Vault mode for op inject (e.g. op). See docs/runtime/vault.md."
    },
    "strategy": { "type": "string" },
    "strategies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "docker_preflight": {
      "type": "boolean",
      "description": "When false, skip Docker reachability preflight when no step uses the container runner (host-only workflows)."
    },
    "compile_hooks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Shell commands run by dockpipe package compile against the staged package copy after validation and before packaging. DockPipe exports DOCKPIPE_COMPILE_KIND, DOCKPIPE_COMPILE_WORKDIR, DOCKPIPE_COMPILE_SOURCE_DIR, and DOCKPIPE_COMPILE_STAGING_DIR."
    },
    "types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "inputs": { "$ref": "#/$defs/input_map" },
    "view": { "$ref": "#/$defs/workflow_view" },
    "model_policy": { "$ref": "#/$defs/model_policy" },
    "image": { "$ref": "#/$defs/image_customization" },
    "steps": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/workflow_step" },
          { "$ref": "#/$defs/async_group" }
        ]
      }
    },
    "finally": {
      "type": "array",
      "description": "Cleanup steps that always run after steps, even when an earlier step fails.",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/workflow_step" },
          { "$ref": "#/$defs/async_group" }
        ]
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "steps": {
            "type": "array",
            "minItems": 1
          }
        },
        "required": ["steps"]
      },
      "then": {
        "not": {
          "anyOf": [
            { "required": ["run"] },
            { "required": ["act"] },
            { "required": ["action"] }
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "finally": {
            "type": "array",
            "minItems": 1
          }
        },
        "required": ["finally"]
      },
      "then": {
        "properties": {
          "steps": {
            "type": "array",
            "minItems": 1
          }
        },
        "required": ["steps"],
        "not": {
          "anyOf": [
            { "required": ["run"] },
            { "required": ["act"] },
            { "required": ["action"] }
          ]
        }
      }
    }
  ]
}
