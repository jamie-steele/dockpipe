# Copy to .env.op.template in your project root (--workdir). THIS FILE IS THE MAPPING:
#   left side  = environment variable name (what r2-publish and DockPipe see)
#   right side = 1Password secret reference (vault / item / field — see CLI docs below)
# Docs: https://developer.1password.com/docs/cli/secrets-reference-syntax
#
# Example matching a "CLOUDFLARE" item in the "DockPipe" vault with fields:
#   url, token, accesskeyid, secretaccesskey
#
# If CLOUDFLARE_ACCOUNT_ID is wrong, add field accountid in 1Password and change the line below.
# (op inject scans the whole file — avoid partial op:// text in comments.)

CLOUDFLARE_API_TOKEN=op://DockPipe/CLOUDFLARE/token
CLOUDFLARE_ACCOUNT_ID=op://DockPipe/CLOUDFLARE/url

# Publish target: plain name, or a real VAR=op://Vault/Item/field line (no partial refs in comments).
R2_BUCKET=your-r2-bucket-name

# R2 S3 keys — same item; used for aws s3 / Wrangler paths and Terraform remote state on R2
AWS_ACCESS_KEY_ID=op://DockPipe/CLOUDFLARE/accesskeyid
AWS_SECRET_ACCESS_KEY=op://DockPipe/CLOUDFLARE/secretaccesskey
R2_STATE_ACCESS_KEY_ID=op://DockPipe/CLOUDFLARE/accesskeyid
R2_STATE_SECRET_ACCESS_KEY=op://DockPipe/CLOUDFLARE/secretaccesskey
