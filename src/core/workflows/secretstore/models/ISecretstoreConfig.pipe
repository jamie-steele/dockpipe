/// <summary>
/// Contract for the bundled secretstore workflow variables.
/// </summary>
public Interface ISecretstoreConfig
{
    /// <summary>Secretstore backend selector. The bundled workflow defaults to dotenv.</summary>
    public string SecretstoreProvider;
    /// <summary>Dotenv-style file loaded before the host command runs.</summary>
    public string SecretstoreEnvFile;
}
